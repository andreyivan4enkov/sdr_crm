{
  "name": "sdr-crm",
  "version": "3.3.0",
  "description": "Персональная CRM для риэлторского агентства",
  "type": "module",
  "license": "MIT",
  "author": "Corpuscul",
  "repository": {
    "type": "git",
    "url": "https://gitverse.ru/Corpuscul/sdr_crm.git"
  },
  "homepage": "https://gitverse.ru/Corpuscul/sdr_crm",
  "bugs": {
    "url": "https://gitverse.ru/Corpuscul/sdr_crm/issues"
  },
  "keywords": [
    "crm",
    "realty",
    "react",
    "vite",
    "tailwindcss"
  ],
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "server",
    "packages/*",
    "packages/aiboard-core",
    "packages/blueprint-core",
    "packages/reactor-core",
    "packages/edo-core",
    "packages/mail-core",
    "packages/i18n",
    "packages/integration-core"
  ],
  "scripts": {
    "dev": "vite",
    "dev:api": "npm run dev -w @sdr-crm/server",
    "dev:all": "node scripts/dev-release.mjs",
    "dev:kill": "node scripts/kill-all-dev.mjs",
    "dev:recover": "node scripts/dev-recover.mjs",
    "dev:verify": "node scripts/verify-dev.mjs",
    "build": "vite build",
    "build:api": "npm run build -w @sdr-crm/server",
    "build:all": "npm run build:api && npm run build",
    "preview": "vite preview",
    "db:up": "docker compose up -d",
    "db:migrate": "npm run db:migrate -w @sdr-crm/server",
    "db:seed": "npm run db:seed -w @sdr-crm/server",
    "db:setup": "npm run db:up && sleep 2 && npm run db:migrate && npm run db:seed",
    "db:reset": "node scripts/db-reset.mjs",
    "db:backup": "bash deploy/scripts/backup-pglite.sh",
    "db:backup:prod": "bash deploy/scripts/backup-db.sh",
    "db:restore": "bash deploy/scripts/restore-db.sh",
    "ops:install": "bash deploy/scripts/install-ops.sh",
    "job:retention": "npm run job:retention -w @sdr-crm/server",
    "extension:load": "echo 'Chrome → Расширения → Режим разработчика → Загрузить распакованное → extension/'",
    "bench": "tsx тест/bench-all.ts",
    "bench:strict": "tsx tests/strict_math_refactor/bench-core.ts",
    "bench:compare": "tsx tests/crm_comparison/compare-bench.ts",
    "bench:stress": "tsx tests/crm_comparison/stress-bench.ts",
    "bench:full": "tsx tests/crm_comparison/compare-bench.ts && tsx tests/crm_comparison/stress-bench.ts",
    "bench:MEM-1.1": "tsx тест/bench-all.ts MEM-1.1",
    "bench:MEM-1.2": "tsx тест/bench-all.ts MEM-1.2",
    "bench:MEM-1.3": "tsx тест/bench-all.ts MEM-1.3",
    "bench:MEM-1.4": "tsx тест/bench-all.ts MEM-1.4",
    "bench:TM-2.1": "tsx тест/bench-all.ts TM-2.1",
    "bench:TM-2.2": "tsx тест/bench-all.ts TM-2.2",
    "bench:TM-2.3": "tsx тест/bench-all.ts TM-2.3",
    "bench:TM-2.4": "tsx тест/bench-all.ts TM-2.4",
    "bench:AI-3.1": "tsx тест/bench-all.ts AI-3.1",
    "bench:AI-3.2": "tsx тест/bench-all.ts AI-3.2",
    "bench:AI-3.3": "tsx тест/bench-all.ts AI-3.3",
    "test:aiboard": "node --import tsx --test packages/aiboard-core/src/**/*.test.ts",
    "test:blueprint": "node --import tsx --test packages/blueprint-core/src/**/*.test.ts",
    "test:edo": "node --import tsx --test packages/edo-core/src/**/*.test.ts",
    "test:local-ai": "node --import tsx --test server/src/lib/aiboard/local-ai.test.ts",
    "test:crm-pipelines": "node --import tsx --test src/lib/crm-pipelines.test.ts",
    "test:server-edo": "node --import tsx --test server/src/lib/edo/*.test.ts",
    "test": "npm run test:aiboard && npm run test:blueprint && npm run test:edo && npm run test:crm-pipelines && npm run test:local-ai",
    "pack:release": "node scripts/pack-release-core.mjs",
    "bench:AI-3.4": "tsx тест/bench-all.ts AI-3.4",
    "bench:AI-4.1": "tsx тест/bench-all.ts AI-4.1"
  },
  "dependencies": {
    "@sdr-crm/api-client": "workspace:*",
    "@sdr-crm/blueprint-core": "workspace:*",
    "dompurify": "^3.4.11",
    "lucide-react": "^0.511.0",
    "mammoth": "^1.12.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1"
  },
  "devDependencies": {
    "@sdr-crm/sdr-core": "file:packages/sdr-core",
    "@tailwindcss/vite": "^4.1.8",
    "@types/dompurify": "^3.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
