# --- Локальная разработка (PGlite, без Docker) ---
USE_PGLITE=1
PGLITE_PATH=./data/jbrealty

# --- Продакшен: удалите USE_PGLITE, укажите PostgreSQL ---
# DATABASE_URL=postgresql://jbrealty:ВАШ_ПАРОЛЬ@localhost:5432/jbrealty

JWT_SECRET=change-this-to-a-long-random-string-min-32-chars

# Демо-аккаунты (публичный репозиторий — только тестовые данные)
ALLOW_DEMO_LOGIN=1
SEED_DEMO_USERS=1

ADMIN_EMAIL=admin@demo.local
ADMIN_LOGIN=admin
ADMIN_PASSWORD=Admin1234
ADMIN_NAME=Администратор (демо)

DEMO_PASSWORD=Operator1234
INTEGRATOR_PASSWORD=Integrator1234
MARKETER_PASSWORD=Marketer1234

PD_OPERATOR_NAME=ООО «JBrealty Demo»
PD_OPERATOR_EMAIL=privacy@demo.local

PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
PUBLIC_URL=http://localhost:5173

LOG_LEVEL=debug

# Продакшен (свой домен, отключите демо):
# NODE_ENV=production
# ALLOW_DEMO_LOGIN=0
# SEED_DEMO_USERS=0
# CORS_ORIGIN=https://ваш-домен.ru
# PUBLIC_URL=https://ваш-домен.ru
