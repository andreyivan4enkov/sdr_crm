# --- Локальная разработка (PGlite, без Docker) ---
USE_PGLITE=1
PGLITE_PATH=./data/crm

# --- Продакшен: удалите USE_PGLITE, укажите PostgreSQL ---
# DATABASE_URL=postgresql://crm:ВАШ_ПАРОЛЬ@localhost:5432/crm

# --- Docker PostgreSQL (docker compose up -d db) ---
# POSTGRES_PASSWORD=change-me-strong-password

JWT_SECRET=change-this-to-a-long-random-string-min-32-chars

# Демо-аккаунты (публичный репозиторий — только тестовые данные)
ALLOW_DEMO_LOGIN=1
SEED_DEMO_USERS=1

ADMIN_EMAIL=admin@demo.local
ADMIN_LOGIN=admin
# Задайте пароль локально (не коммитьте реальные значения)
ADMIN_PASSWORD=
ADMIN_NAME=Администратор (демо)

DEMO_PASSWORD=
INTEGRATOR_PASSWORD=
MARKETER_PASSWORD=
DEAL_MANAGER_PASSWORD=

PD_OPERATOR_NAME=ООО «CRM Demo»
PD_OPERATOR_EMAIL=privacy@demo.local

PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
PUBLIC_URL=http://localhost:5173

LOG_LEVEL=debug

# Продакшен (свой домен, отключите демо):
# NODE_ENV=production
# ALLOW_DEMO_LOGIN=0
# SEED_DEMO_USERS=0
# CORS_ORIGIN=https://ваш-домен.ru
# PUBLIC_URL=https://ваш-домен.ru
