{
  "manifest_version": 3,
  "name": "SDR CRM",
  "description": "Быстрые действия CRM: создать лид, открыть карточку с сайта объявления",
  "version": "0.1.0",
  "action": {
    "default_title": "SDR CRM",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://localhost:5173/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
