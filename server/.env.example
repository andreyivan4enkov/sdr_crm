# Скопируйте: cp deploy/.env.example server/.env

# --- Локальная разработка (PGlite, без Docker) ---
USE_PGLITE=1
PGLITE_PATH=./data/crm

JWT_SECRET=change-this-to-a-long-random-string-min-32-chars

ALLOW_DEMO_LOGIN=1
SEED_DEMO_USERS=1

ADMIN_EMAIL=admin@demo.local
ADMIN_LOGIN=admin
ADMIN_PASSWORD=Admin1234
ADMIN_NAME=Администратор (демо)

DEMO_PASSWORD=Operator1234
INTEGRATOR_PASSWORD=Integrator1234
MARKETER_PASSWORD=Marketer1234

PD_OPERATOR_NAME=ООО «SDR CRM Demo»
PD_OPERATOR_EMAIL=privacy@demo.local

PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
PUBLIC_URL=http://localhost:5173

LOG_LEVEL=debug

# --- SDR hybrid layer (Classic + Sparse Distributed Representations) ---
# SDR_SEARCH=1
# SDR_AUDIT=1
# SDR_SCORING=1
# SDR_GRAPH=1
# SDR_FUNNEL_CA=1
# SDR_INDEX_ON_START=1
# SDR_RECALL_LIMIT=50
# SDR_AUDIT_THRESHOLD=12
# SDR_SEARCH_RADIUS=22
# SDR_MAX_LEADS=500000
