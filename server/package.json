{
  "name": "@sdr-crm/server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ../scripts/dev-api.mjs",
    "build": "tsc",
    "test": "node --import tsx --test src/lib/**/*.test.ts",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:avatars": "tsx src/db/backfill-avatars.ts",
    "job:retention": "tsx src/jobs/retention-purge.ts",
    "sdr:reindex": "tsx scripts/sdr-reindex.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.2",
    "@hono/node-server": "^1.14.1",
    "@sdr-crm/ai-schemas": "file:../packages/ai-schemas",
    "@sdr-crm/aiboard-core": "file:../packages/aiboard-core",
    "@sdr-crm/blueprint-core": "file:../packages/blueprint-core",
    "@sdr-crm/reactor-core": "file:../packages/reactor-core",
    "@sdr-crm/site-core": "file:../packages/site-core",
    "@sdr-crm/edo-core": "file:../packages/edo-core",
    "@sdr-crm/mail-core": "file:../packages/mail-core",
    "@sdr-crm/i18n": "file:../packages/i18n",
    "@sdr-crm/integration-core": "file:../packages/integration-core",
    "@sdr-crm/sdr-core": "file:../packages/sdr-core",
    "bcryptjs": "^3.0.2",
    "dompurify": "^3.2.6",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.43.1",
    "hono": "^4.7.10",
    "ioredis": "^5.6.1",
    "isolated-vm": "^5.0.4",
    "jose": "^6.0.11",
    "jsdom": "^26.1.0",
    "otpauth": "^9.4.0",
    "postgres": "^3.4.5",
    "web-push": "^3.6.7",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.21",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.4",
    "typescript": "~5.8.3"
  }
}
